s (FedAvg, excl. style_head/BN/M)\r\n  352:         self._aggregate_shared(models)\r\n  353: \r\n  354:         # 2. Collect per-client style (μ_sty, Σ_sty)\r\n  355:         for cid, style in zip(self.received_clients, style_stats_list):\r\n  356:             if style is not None:\r\n  357:                 self.style_bank[cid] = style\r\n  358: \r\n  359:         # 3. Rebuild pooled whitening once we have enough clients\r\n  360:         # (按 uw flag 开关, 消融实验用)\r\n  361:         if getattr(self, 'uw', 1) == 1 and len(self.style_bank) >= self.mcw:\r\n  362:             self._compute_pooled_whitening()\r\n  363: \r\n  364:         # 3.5. Save checkpoint at last round (if se=1, for EXP-099 SGPA inference)\r\n  365:         if int(getattr(self, 'se', 0)) == 1 and self.current_round >= self.num_rounds:\r\n  366:             self._save_sgpa_checkpoint()\r\n  367: \r\n  368:         # 4. Diagnostic: Layer 2 指标 (client_center_variance + param_drift)\r\n  369:         if self.dl_agg is not None:\r\n  370:             metrics = {}\r\n  371:             # client_center_variance: 只对所有 client 都有样本的类算方差\r\n  372:             # (NaN-filled 缺失类会让 stack 混入 zero, 导致假 variance)\r\n  373:             valid_centers = [c for c in class_centers_list if c is not None]\r\n  374:             if len(valid_centers) >= 2:\r\n  375:                 stacked = torch.stack(valid_centers, dim=0)  # [N, K, d]\r\n  376:                 nan_mask = stacked.isnan().any(dim=-1)       # [N, K]\r\n  377:                 all_valid_cls = ~nan_mask.any(dim=0)         # [K] True iff 所有 client 都有此类\r\n  378:                 if all_valid_cls.any():\r\n  379:                     filtered = stacked[:, all_valid_cls, :]   # [N, K_valid, d]\r\n  380:                     metrics['client_center_var'] = DL.client_center_variance(\r\n  381:                         [filtered[i] for i in range(filtered.shape[0])])\r\n  382:                     metrics['n_valid_classes'] = int(all_valid_cls.sum().item())\r\n  383:             # param_drift: 聚合前各 client conv1.weight 与 global 的 L2 距离\r\n  384:             try:\r\n  385:                 global_w = self.model.encoder.features.conv1.weight.detach().cpu().flatten()\r\n  386:                 client_ws = [m.encoder.features.conv1.weight.detach().cpu().flatten()\r\n  387:                              for m in models]\r\n  388:                 metrics['param_drift'] = DL.param_drift(client_ws, global_w)\r\n  389:             except (AttributeError, RuntimeError):\r\n  390:                 pass\r\n  391:             if metrics:\r\n  392:                 self.dl_agg.record(round_id=self.current_round, metrics_dict=metrics)\r\n  393: \r\n  394:     def _aggregate_shared(self, models):\r\n  395:         \"\"\"FedAvg on shared keys only (sample-size weighted).\"\"\"\r\n  396:         if not models:\r\n  397:             return\r\n  398:         weights = np.array(\r\n  399:             [len(self.clients[cid].train_data) for cid in self.received_clients],\r\n  400:             dtype=float,\r\n  401:         )\r\n  402:         weights /= weights.sum()\r\n  403: \r\n  404:         global_dict = self.model.state_dict()\r\n  405:         model_dicts = [m.state_dict() for m in models]\r\n  406:         for k in self.shared_keys:\r\n  407:             if 'num_batches_tracked' in k:\r\n  408:                 continue\r\n  409:             global_dict[k] = sum(w * md[k] for w, md in zip(weights, model_dicts))\r\n  410:         self.model.load_state_dict(global_dict, strict=False)\r\n","exit_code":0,"status":"completed"}}
