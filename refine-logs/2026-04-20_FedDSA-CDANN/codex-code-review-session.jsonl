8*64+64 = 8256; Linear(64,4) = 64*4+4 = 260 → 8516\u001b[0m\r\n>         assert 5000 < total < 15000, f\"unexpected \u001b[7mdom_head\u001b[0m param count: {total}\"\u001b[0m\r\n\u001b[7m\u001b[0m  \u001b[0m\r\n>     def test_ca1_\u001b[7mdom_head\u001b[0m_in_state_dict(self):\r\n>         \"\"\"\u001b[7mdom_head\u001b[0m 参数在 state_dict 里 → 会被 FedAvg 聚合 (默认路径).\"\"\"\r\n>         model = FedDSASGPAModel(num_classes=10, \u001b[7mca=\u001b[0m1, num_clients=4)\u001b[0m\r\n\u001b[7m\u001b[0m          keys = model.state_dict().keys()\u001b[0m\r\n>         dom_keys = [k for k in keys if '\u001b[7mdom_head\u001b[0m' in k]\r\n>         assert len(dom_keys) > 0, \"\u001b[7mdom_head\u001b[0m 必须在 state_dict 里 (FedAvg 聚合)\"\r\n>         # 确认不在常见的 private_keys 规则里 (style_head 是 private, \u001b[7mdom_head\u001b[0m 不是)\u001b[0m\r\n\u001b[7m\u001b[0m          for k in dom_keys:\u001b[0m\r\n>             assert 'style_head' not in k, \"\u001b[7mdom_head\u001b[0m 不应包含 style_head, 避免被 private key 规则误匹配\"\u001b[0m\r\n\u001b[7m\u001b[0m  \u001b[0m\r\n\u001b[7m\u001b[0m      def test_ca1_backward_asymmetric_gradient_directions(self):\u001b[0m\r\n>         \"\"\"z_sem 走 \u001b[7mGRL\u001b[0m 反向, z_sty 走正向: encoder 端收到的梯度符号应相反.\"\"\"\u001b[0m\r\n\u001b[7m\u001b[0m          torch.manual_seed(0)\u001b[0m\r\n>         model = FedDSASGPAModel(num_classes=7, proj_dim=128, \u001b[7mca=\u001b[0m1, num_clients=4)\u001b[0m\r\n\u001b[7m\u001b[0m          model.train()\u001b[0m\r\n\u001b[7m\u001b[0m          x = torch.randn(4, 3, 224, 224)\u001b[0m\r\n\u001b[7m\u001b[0m          d = torch.tensor([0, 0, 0, 0])  # 所有样本都来自 client 0\u001b[0m\r\n          z_sem = model.get_semantic(h)\r\n          z_sty = model.get_style(h)\r\n  \r\n>         # 只算 L_dom_sem (z_sem 路径, \u001b[7mGRL\u001b[0m 反向, lam=1.0)\u001b[0m\r\n>         dom_logits_sem = model.\u001b[7mdom_head\u001b[0m(grl(z_sem, 1.0))\u001b[0m\r\n\u001b[7m\u001b[0m          l_dom_sem = F.cross_entropy(dom_logits_sem, d)\u001b[0m\r\n\u001b[7m\u001b[0m          l_dom_sem.backward(retain_graph=True)\u001b[0m\r\n\u001b[7m\u001b[0m          grad_sem_encoder_gru = next(model.semantic_head.parameters()).grad.clone()\u001b[0m\r\n          model.zero_grad()\r\n  \r\n>         # 只算 L_dom_sty (z_sty 路径, 无 \u001b[7mGRL\u001b[0m)\u001b[0m\r\n>         dom_logits_sty = model.\u001b[7mdom_head\u001b[0m(z_sty)\u001b[0m\r\n\u001b[7m\u001b[0m          l_dom_sty = F.cross_entropy(dom_logits_sty, d)\u001b[0m\r\n\u001b[7m\u001b[0m          l_dom_sty.backward()\u001b[0m\r\n\u001b[7m\u001b[0m          grad_sty_encoder = next(model.style_head.parameters()).grad.clone()\u001b[0m\r\n          model.zero_grad()\r\n  \r\n>         # 关键: z_sem 路径的 semantic_head 梯度应该存在 (\u001b[7mGRL\u001b[0m 只反转不清零)\u001b[0m\r\n\u001b[7m\u001b[0m          assert grad_sem_encoder_gru.norm().item() > 0, \"semantic_head 应有梯度\"\u001b[0m\r\n\u001b[7m\u001b[0m          # style_head 梯度应该存在 (正向)\u001b[0m\r\n\u001b[7m\u001b[0m          assert grad_sty_encoder.norm().item() > 0, \"style_head 应有梯度\"\u001b[0m\r\n  \r\n  \r\n  class TestCAFlagBackwardCompat:\r\n>     \"\"\"\u001b[7mca=\u001b[0m0 时行为等价于 baseline (无 CDANN).\"\"\"\u001b[0m\r\n\u001b[7m\u001b[0m  \u001b[0m\r\n\u001b[7m\u001b[0m      def test_ca0_forward_equivalent_to_baseline(self):\u001b[0m\r\n>         \"\"\"\u001b[7mca=\u001b[0m0 和未传 ca 的 Model forward 完全相同.\"\"\"\u001b[0m\r\n\u001b[7m\u001b[0m          torch.manual_seed(42)\u001b[0m\r\n>         m1 = FedDSASGPAModel(num_classes=10, \u001b[7mca=\u001b[0m0, use_etf=False)\u001b[0m\r\n\u001b[7m\u001b[0m          torch.manual_seed(42)\u001b[0m\r\n>         m2 = FedDSASGPAModel(num_classes=10, use_etf=False)  # 默认 \u001b[7mca=\u001b[0m0\u001b[0m\r\n\u001b[7m\u001b[0m          m1.eval()\u001b[0m\r\n\u001b[7m\u001b[0m          m2.eval()\u001b[0m\r\n\u001b[7m\u001b[0m          x = torch.randn(4, 3, 224, 224)\u001b[0m\r\n          with torch.no_grad():\r\n              y1 = m1(x)\r\n              y2 = m2(x)\r\n>         assert torch.allclose(y1, y2, atol=1e-6), 