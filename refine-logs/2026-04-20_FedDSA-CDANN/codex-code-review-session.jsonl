=0 时 \u001b[7mGRL\u001b[0m.backward 应该返回 0 梯度.\"\"\"\u001b[0m\r\n\u001b[7m\u001b[0m          x = torch.randn(4, 128, requires_grad=True)\u001b[0m\r\n>         y = \u001b[7mgrl\u001b[0m(x, lam=0.0)\u001b[0m\r\n\u001b[7m\u001b[0m          loss = y.sum()\u001b[0m\r\n\u001b[7m\u001b[0m          loss.backward()\u001b[0m\r\n\u001b[7m\u001b[0m          assert torch.allclose(x.grad, torch.zeros_like(x))\u001b[0m\r\n  \r\n      def test_backward_lam_one_flips_gradient(self):\r\n>         \"\"\"lam=1 时 \u001b[7mGRL\u001b[0m.backward 应该完全反转梯度.\"\"\"\u001b[0m\r\n\u001b[7m\u001b[0m          x = torch.randn(4, 128, requires_grad=True)\u001b[0m\r\n>         y = \u001b[7mgrl\u001b[0m(x, lam=1.0)\u001b[0m\r\n\u001b[7m\u001b[0m          # 模拟分类 loss 梯度\u001b[0m\r\n\u001b[7m\u001b[0m          loss = y.pow(2).sum()\u001b[0m\r\n\u001b[7m\u001b[0m          loss.backward()\u001b[0m\r\n>         # 无 \u001b[7mGRL\u001b[0m 时 dL/dx = 2x, 反转后是 -2x\u001b[0m\r\n\u001b[7m\u001b[0m          assert torch.allclose(x.grad, -2 * x, atol=1e-5)\u001b[0m\r\n\u001b[7m\u001b[0m  \u001b[0m\r\n\u001b[7m\u001b[0m  \u001b[0m\r\n      \"\"\"DANN λ_adv schedule 三段式.\"\"\"\r\n  \r\n      def test_warmup_off(self):\r\n>         assert \u001b[7mcompute_lambda_adv\u001b[0m(0, 20, 40) == 0.0\u001b[0m\r\n>         assert \u001b[7mcompute_lambda_adv\u001b[0m(10, 20, 40) == 0.0\r\n>         assert \u001b[7mcompute_lambda_adv\u001b[0m(19, 20, 40) == 0.0\u001b[0m\r\n\u001b[7m\u001b[0m  \u001b[0m\r\n\u001b[7m\u001b[0m      def test_linear_ramp(self):\u001b[0m\r\n\u001b[7m\u001b[0m          # R=20..40 linear 0 → 1\u001b[0m\r\n>         assert \u001b[7mcompute_lambda_adv\u001b[0m(20, 20, 40) == 0.0\r\n>         assert abs(\u001b[7mcompute_lambda_adv\u001b[0m(30, 20, 40) - 0.5) < 1e-6\r\n>         assert abs(\u001b[7mcompute_lambda_adv\u001b[0m(35, 20, 40) - 0.75) < 1e-6\u001b[0m\r\n\u001b[7m\u001b[0m  \u001b[0m\r\n\u001b[7m\u001b[0m      def test_full(self):\u001b[0m\r\n>         assert \u001b[7mcompute_lambda_adv\u001b[0m(40